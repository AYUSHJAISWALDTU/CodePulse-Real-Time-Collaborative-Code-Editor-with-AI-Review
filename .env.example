# ── Database ──────────────────────────────────────────────
DATABASE_URL=postgresql://codepulse:codepulse@localhost:5432/codepulse

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-random-64-char-string
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# ── Services ──────────────────────────────────────────────
API_PORT=4000
REALTIME_PORT=4001
WORKER_PORT=4002
WEB_PORT=3000

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000

# ── Node ──────────────────────────────────────────────────
NODE_ENV=development
